# Copy this file to .env and fill in your keys
# These are used as fallbacks if keys are not sent from the browser

# Your Hostfully API key (from Agency Settings in Hostfully)
HOSTFULLY_API_KEY=your_hostfully_key_here

# Your Claude API key (from console.anthropic.com)
CLAUDE_API_KEY=sk-ant-your_claude_key_here

# Port (Render sets this automatically, leave as is)
PORT=3000
